#include <iostream>
#include <string>
#include <random>
#include <vector>

// Function to generate the password
std::string generatePassword(int length, bool useUpper, bool useLower, bool useNumbers, bool useSymbols) {
    
    const std::string upperChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const std::string lowerChars = "abcdefghijklmnopqrstuvwxyz";
    const std::string numberChars = "0123456789";
    const std::string symbolChars = "!@#$%^&*()_+-=[]{}|;:,.<>?";

    std::string charPool = "";

    // Build the pool of characters based on user selection
    if (useUpper) charPool += upperChars;
    if (useLower) charPool += lowerChars;
    if (useNumbers) charPool += numberChars;
    if (useSymbols) charPool += symbolChars;

    // Fallback if user selected nothing
    if (charPool.empty()) {
        charPool = lowerChars; // Default to lowercase
    }

    // Random Number Generation (C++11 style)
    std::random_device rd;
    std::mt19937 generator(rd()); // Seed the generator
    std::uniform_int_distribution<int> distribution(0, charPool.length() - 1);

    std::string password = "";
    for (int i = 0; i < length; ++i) {
        int randomIndex = distribution(generator);
        password += charPool[randomIndex];
    }

    return password;
}

int main() {
    int length;
    char choice;
    bool useUpper, useLower, useNumbers, useSymbols;

    std::cout << "=== C++ Password Generator ===" << std::endl;

    // 1. Get Length
    std::cout << "Enter password length: ";
    while (!(std::cin >> length) || length <= 0) {
        std::cout << "Please enter a valid positive number: ";
        std::cin.clear();
        std::cin.ignore();
    }

    // 2. Get Character Options
    std::cout << "Include Uppercase letters? (y/n): ";
    std::cin >> choice;
    useUpper = (choice == 'y' || choice == 'Y');

    std::cout << "Include Lowercase letters? (y/n): ";
    std::cin >> choice;
    useLower = (choice == 'y' || choice == 'Y');

    std::cout << "Include Numbers? (y/n): ";
    std::cin >> choice;
    useNumbers = (choice == 'y' || choice == 'Y');

    std::cout << "Include Symbols? (y/n): ";
    std::cin >> choice;
    useSymbols = (choice == 'y' || choice == 'Y');

    // 3. Generate and Display
    std::string password = generatePassword(length, useUpper, useLower, useNumbers, useSymbols);

    std::cout << "\n----------------------------------" << std::endl;
    std::cout << "Generated Password: " << password << std::endl;
    std::cout << "----------------------------------" << std::endl;

    return 0;
}
